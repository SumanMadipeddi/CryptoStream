# Frontend Environment Variables
# Set these in your Vercel deployment settings

# Backend API URL (set to your Railway URL in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL (set to your Railway WebSocket URL in production)
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# Example production values:
# NEXT_PUBLIC_API_URL=https://your-app-name.railway.app
# NEXT_PUBLIC_WS_URL=wss://your-app-name.railway.app

{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next",
      "config": {
        "distDir": ".next"
      }
    }
  ],
  "installCommand": "pnpm install --recursive",
  "buildCommand": "cd frontend && pnpm build",
  "outputDirectory": "frontend/.next"
}

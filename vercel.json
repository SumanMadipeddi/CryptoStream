{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "installCommand": "pnpm install --recursive",
  "buildCommand": "pnpm --filter frontend build",
  "outputDirectory": "frontend/.next"
}
